

{% liquid
  assign max_items = section.settings.max_products
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  data-testid="product-list"
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-resource-list
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
    {% if section.settings.enable_custom_product_image_radius %}
      {% liquid
        assign pl_radius = section.settings.product_image_border_radius_px | remove: 'px' | strip
        if pl_radius == blank
          assign pl_radius = '500'
        endif
      %}
      --product-list-image-radius: {{ pl_radius }}px;
    {% else %}
      {% comment %} Color schemes do not set --border-radius; use theme product corner radius. {% endcomment %}
      --product-list-image-radius: {{ settings.product_corner_radius }}px;
    {% endif %}
    {% liquid
      assign image_slot_radius_css = ''
      if section.settings.image_slots_enable_custom_border_radius_px
        assign slot_px = section.settings.image_slots_custom_border_radius_px | remove: 'px' | strip
        if slot_px == blank
          assign slot_px = '500'
        endif
        assign image_slot_radius_css = slot_px | append: 'px'
      elsif section.settings.image_slots_border_radius != blank and section.settings.image_slots_border_radius > 0
        assign image_slot_radius_css = section.settings.image_slots_border_radius | append: 'px'
      endif
    %}
    {% if image_slot_radius_css != '' %}
      --product-list-image-slot-radius: {{ image_slot_radius_css }};
    {% else %}
      --product-list-image-slot-radius: var(--product-list-image-radius);
    {% endif %}
  "
>
  <div class="section-resource-list__header">
    {%- content_for 'block', type: '_product-list-content', id: 'static-header' -%}
  </div>

  {% capture list_items %}
    {% liquid
      assign slot_1_active = false
      assign slot_2_active = false
      assign slot_3_active = false
      assign slot_4_active = false
      assign slot_aspect_ratio = '1 / 1.25'
      if section.settings.image_slot_1_image != blank
        assign slot_1_active = true
      endif
      if section.settings.image_slot_2_image != blank
        assign slot_2_active = true
      endif
      if section.settings.image_slot_3_image != blank
        assign slot_3_active = true
      endif
      if section.settings.image_slot_4_image != blank
        assign slot_4_active = true
      endif
      assign active_slot_count = 0
      if slot_1_active
        assign active_slot_count = active_slot_count | plus: 1
      endif
      if slot_2_active
        assign active_slot_count = active_slot_count | plus: 1
      endif
      if slot_3_active
        assign active_slot_count = active_slot_count | plus: 1
      endif
      if slot_4_active
        assign active_slot_count = active_slot_count | plus: 1
      endif
    %}
    {% if section.settings.collection != blank and shop.products_count != 0 %}
      {% paginate section.settings.collection.products by max_items %}
        {% liquid
          assign collection_products = section.settings.collection.products
          assign product_count = collection_products.size
          assign total_render = product_count | plus: active_slot_count
          if total_render > max_items
            assign total_render = max_items
          endif
          assign product_idx = 0
        %}
        {% for pos in (1..total_render) %}
          {% liquid
            assign is_slot = false
            assign slot_image = blank
            assign slot_link = blank
            if slot_1_active and section.settings.image_slot_1_position == pos
              assign is_slot = true
              assign slot_image = section.settings.image_slot_1_image
              assign slot_link = section.settings.image_slot_1_link
            elsif slot_2_active and section.settings.image_slot_2_position == pos
              assign is_slot = true
              assign slot_image = section.settings.image_slot_2_image
              assign slot_link = section.settings.image_slot_2_link
            elsif slot_3_active and section.settings.image_slot_3_position == pos
              assign is_slot = true
              assign slot_image = section.settings.image_slot_3_image
              assign slot_link = section.settings.image_slot_3_link
            elsif slot_4_active and section.settings.image_slot_4_position == pos
              assign is_slot = true
              assign slot_image = section.settings.image_slot_4_image
              assign slot_link = section.settings.image_slot_4_link
            endif
          %}
          <div class="resource-list__item">
            {% if is_slot %}
              <product-card class="product-card product-list__image-slot">
                <div class="product-card__content layout-panel-flex layout-panel-flex--column product-grid__card">
                  <div
                    class="card-gallery product-list__image-slot-image"
                    style="--gallery-aspect-ratio: {{ slot_aspect_ratio }};"
                  >
                    {% if slot_link != blank %}
                      <a href="{{ slot_link }}" class="contents product-list__image-slot-link">
                    {% endif %}
                    <div class="product-media" style="--ratio: {{ slot_image.aspect_ratio | default: 1 }};"> 
                      {{
                        slot_image
                        | image_url: width: 2400
                        | image_tag:
                          width: slot_image.width,
                          widths: '320, 480, 640, 832, 1200, 1600, 1920, 2400',
                          height: slot_image.height,
                          class: 'product-media__image product-list__image-slot-media',
                          alt: slot_image.alt
                      }}
                    </div>
                    {% if slot_link != blank %}
                      </a>
                    {% endif %}
                  </div>
                </div>
              </product-card>
            {% else %}
              {% assign product = collection_products[product_idx] %}
              {% if product != blank %}
                {% # theme-check-disable UniqueStaticBlockId %}
                  {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: product %}
                {% # theme-check-enable UniqueStaticBlockId %}
                {% assign product_idx = product_idx | plus: 1 %}
              {% endif %}
            {% endif %}
          </div>
          {% unless forloop.last %}
            <!--@list/split-->
          {% endunless %}
        {% endfor %}
      {% endpaginate %}
    {% else %}
      {% liquid
        assign total_render_fallback = max_items | plus: active_slot_count
        if total_render_fallback > max_items
          assign total_render_fallback = max_items
        endif
      %}
      {% for pos in (1..max_items) %}
        {% liquid
          assign is_slot = false
          assign slot_image = blank
          assign slot_link = blank
          if slot_1_active and section.settings.image_slot_1_position == pos
            assign is_slot = true
            assign slot_image = section.settings.image_slot_1_image
            assign slot_link = section.settings.image_slot_1_link
          elsif slot_2_active and section.settings.image_slot_2_position == pos
            assign is_slot = true
            assign slot_image = section.settings.image_slot_2_image
            assign slot_link = section.settings.image_slot_2_link
          elsif slot_3_active and section.settings.image_slot_3_position == pos
            assign is_slot = true
            assign slot_image = section.settings.image_slot_3_image
            assign slot_link = section.settings.image_slot_3_link
          elsif slot_4_active and section.settings.image_slot_4_position == pos
            assign is_slot = true
            assign slot_image = section.settings.image_slot_4_image
            assign slot_link = section.settings.image_slot_4_link
          endif
        %}
        <div class="resource-list__item">
          {% if is_slot %}
            <product-card class="product-card product-list__image-slot">
              <div class="product-card__content layout-panel-flex layout-panel-flex--column product-grid__card">
                <div
                  class="card-gallery product-list__image-slot-image"
                  style="--gallery-aspect-ratio: {{ slot_aspect_ratio }};"
                >
                  {% if slot_link != blank %}
                    <a href="{{ slot_link }}" class="contents product-list__image-slot-link">
                  {% endif %}
                  <div class="product-media" style="--ratio: {{ slot_aspect_ratio }};">
                    {{
                      slot_image
                      | image_url: width: 2400
                      | image_tag:
                        width: slot_image.width,
                        widths: '320, 480, 640, 832, 1200, 1600, 1920, 2400',
                        height: slot_image.height,
                        class: 'product-media__image product-list__image-slot-media',
                        alt: slot_image.alt
                    }}
                  </div>
                  {% if slot_link != blank %}
                    </a>
                  {% endif %}
                </div>
              </div>
            </product-card>
          {% else %}
            {% # theme-check-disable UniqueStaticBlockId %}
              {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: null %}
            {% # theme-check-enable UniqueStaticBlockId %}
          {% endif %}
        </div>
        {% unless forloop.last %}
          <!--@list/split-->
        {% endunless %}
      {% endfor %}
    {% endif %}
  {% endcapture %}

  {% liquid
    # Create an array from the list items to be used for different layout types
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
  %}

  {% render 'resource-list',
    list_items: list_items,
    list_items_array: list_items_array,
    settings: section.settings,
    slide_count: list_items_array.size,
    content_type: 'products',
    test_id: 'resource-list-grid'
  %}

  <div
    class="section-resource-list__content"
    style="--horizontal-alignment: {{ section.settings.horizontal_alignment }};"
  >
    {%- content_for 'blocks' -%}
  </div>
</div>

{% stylesheet %}
  [data-testid="product-list"] .text-block h3 {
    font-size: 32px;
    text-transform: uppercase;
    font-weight: 700;
    font-style: Bold;
    font-size: 32px;
    line-height: 100%;
    letter-spacing: 2%;
  }

  /*
   * Shell radius: product cards use Product image; image slots use Image slots border settings
   * (--product-list-image-slot-radius on section, see base.css for inner clip).
   */
  [data-testid="product-list"] .card-gallery {
    --corner-radius: var(--product-list-image-radius);
    border-radius: var(--product-list-image-radius);
    overflow: hidden;
  }

  [data-testid="product-list"] .card-gallery.product-list__image-slot-image {
    --corner-radius: var(--product-list-image-slot-radius);
    border-radius: var(--product-list-image-slot-radius);
  }

  [data-testid="product-list"] .product-list__image-slot {
    display: block;
  }

  [data-testid="product-list"] .product-list__image-slot-image {
    overflow: hidden;
    width: 100%;
    display: block;
  }

  [data-testid="product-list"] .product-list__image-slot-link {
    display: block;
    width: 100%;
  }

  [data-testid="product-list"] .product-list__image-slot-media {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  [data-testid="product-list"] .product-list__image-slot-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f3f3f3;
    border-radius: var(--product-list-image-slot-radius);
    color: #999;
    font-size: 14px;
  }

  [data-testid="product-list"] .product-card__content .group-block-content {
    align-items: center;
  }

  [data-testid="product-list"] .product-card__content .text-block,
  [data-testid="product-list"] .product-card__content product-price, product-recommendations .product-card__content .text-block > * {
    width: 100%;
    align-items: center;
  }

  [data-testid="product-list"] .product-card__content .text-block > *,
  [data-testid="product-list"] .product-card__content product-price .price, product-recommendations .product-card__content .text-block > * {
    width: 100%;
    text-align: center !important;
    font-family: 'DM Sans', var(--font-body--family);
    font-weight: 400;
    font-style: normal;
    line-height: 1;
    letter-spacing: 0;
  }
  
  [data-testid="product-list"] .product-card__content .text-block > *, product-recommendations .product-card__content .text-block > * {
    font-size: 20px;
    color: #000;
  }
  
  [data-testid="product-list"] .product-card__content product-price .price, product-recommendations .product-card__content product-price .price  {
    font-size: 16px;
    color: #5b5757;
  }


  @media (max-width: 767px) {
    [data-testid="product-list"] .text-block h3 { 
      font-size: 24px;
    }
    [data-testid="product-list"] .product-card__content .text-block > *,
    [data-testid="product-list"] .product-card__content product-price .price, product-recommendations .product-card__content product-price .price, product-recommendations .product-card__content .text-block > * {
    font-size: 18px;
  }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_list",
  "class": "ui-test-product-list",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:settings.collection"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.layout_type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "carousel",
          "label": "t:options.carousel"
        },
        {
          "value": "editorial",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "checkbox",
      "id": "carousel_on_mobile",
      "label": "t:settings.carousel_on_mobile",
      "default": false,
      "visible_if": "{{ section.settings.layout_type != 'carousel' }}"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "t:settings.product_count",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:settings.columns",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4,
      "visible_if": "{{ section.settings.layout_type != 'editorial' }}"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "t:settings.mobile_columns",
      "options": [
        {
          "value": "1",
          "label": "t:options.one_number"
        },
        {
          "value": "2",
          "label": "t:options.two_number"
        }
      ],
      "default": "2",
      "visible_if": "{{ section.settings.layout_type == 'grid' and section.settings.carousel_on_mobile == false }}"
    },
    {
      "type": "select",
      "id": "mobile_card_size",
      "label": "t:settings.mobile_columns",
      "options": [
        {
          "value": "60cqw",
          "label": "t:options.one_number"
        },
        {
          "value": "44cqw",
          "label": "t:options.two_number"
        }
      ],
      "default": "60cqw",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.layout_type == 'grid' or section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "range",
      "id": "rows_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.layout_type == 'grid'}}"
    },
    {
      "type": "header",
      "content": "t:content.carousel_navigation",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "select",
      "id": "icons_style",
      "label": "t:settings.icon",
      "options": [
        {
          "value": "arrow",
          "label": "t:options.arrows"
        },
        {
          "value": "chevron",
          "label": "t:options.chevrons"
        },
        {
          "value": "arrows_large",
          "label": "t:options.arrows_large"
        },
        {
          "value": "chevron_large",
          "label": "t:options.chevron_large"
        },
        {
          "value": "none",
          "label": "t:options.none"
        }
      ],
      "default": "arrow",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "select",
      "id": "icons_shape",
      "label": "t:settings.icon_background",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "circle",
          "label": "t:options.circle"
        },
        {
          "value": "square",
          "label": "t:options.square"
        }
      ],
      "default": "none",
      "visible_if": "{{ section.settings.icons_style != 'none' and section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Product image"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Image slots"
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "range",
      "id": "image_slots_border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0,
      "info": "0 = same corner radius as product media (Product image above). Use 1–32 for a fixed radius on slots only."
    },
    {
      "type": "checkbox",
      "id": "image_slots_enable_custom_border_radius_px",
      "label": "Enable custom corner radius (px)",
      "default": false
    },
    {
      "type": "text",
      "id": "image_slots_custom_border_radius_px",
      "label": "Custom corner radius (px)",
      "default": "500",
      "info": "Enter number, e.g. 500",
      "visible_if": "{{ section.settings.image_slots_enable_custom_border_radius_px }}"
    },
    {
      "type": "image_picker",
      "id": "image_slot_1_image",
      "label": "Slot 1 — Image"
    },
    {
      "type": "range",
      "id": "image_slot_1_position",
      "label": "Slot 1 — Replace position",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 2
    },
    {
      "type": "url",
      "id": "image_slot_1_link",
      "label": "Slot 1 — Link (optional)"
    },
    {
      "type": "image_picker",
      "id": "image_slot_2_image",
      "label": "Slot 2 — Image"
    },
    {
      "type": "range",
      "id": "image_slot_2_position",
      "label": "Slot 2 — Replace position",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 4
    },
    {
      "type": "url",
      "id": "image_slot_2_link",
      "label": "Slot 2 — Link (optional)"
    },
    {
      "type": "image_picker",
      "id": "image_slot_3_image",
      "label": "Slot 3 — Image"
    },
    {
      "type": "range",
      "id": "image_slot_3_position",
      "label": "Slot 3 — Position",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 6
    },
    {
      "type": "url",
      "id": "image_slot_3_link",
      "label": "Slot 3 — Link (optional)"
    },
    {
      "type": "image_picker",
      "id": "image_slot_4_image",
      "label": "Slot 4 — Image"
    },
    {
      "type": "range",
      "id": "image_slot_4_position",
      "label": "Slot 4 — Position",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "url",
      "id": "image_slot_4_link",
      "label": "Slot 4 — Link (optional)"
    }
  ],
  "presets": [
    {
      "name": "t:names.products_grid",
      "category": "t:categories.products",
      "settings": {
        "collection": "",
        "max_products": 8,
        "layout_type": "grid",
        "carousel_on_mobile": false,
        "columns": 4,
        "mobile_columns": "2",
        "columns_gap": 8,
        "rows_gap": 24,
        "icons_style": "arrow",
        "icons_shape": "none",
        "section_width": "page-width",
        "gap": 28,
        "color_scheme": "scheme-1",
        "padding-block-start": 48,
        "padding-block-end": 48
      },
      "blocks": {
        "static-header": {
          "type": "_product-list-content",
          "name": "t:names.header",
          "static": true,
          "settings": {
            "content_direction": "row",
            "vertical_on_mobile": false,
            "horizontal_alignment": "space-between",
            "vertical_alignment": "flex-end",
            "align_baseline": true,
            "horizontal_alignment_flex_direction_column": "flex-start",
            "vertical_alignment_flex_direction_column": "center",
            "gap": 12,
            "width": "fill",
            "custom_width": 100,
            "width_mobile": "fill",
            "custom_width_mobile": 100,
            "height": "fit",
            "custom_height": 100,
            "inherit_color_scheme": true,
            "color_scheme": "",
            "background_media": "none",
            "video_position": "cover",
            "background_image_position": "cover",
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 0,
            "padding-block-start": 0,
