
{% liquid
  assign is_pdp = false
  if request.page_type == 'product'
    assign is_pdp = true
  endif

  assign pdp_marquee = nil
  if is_pdp
    assign pdp_marquee = product.metafields.custom.plynacy_pasek_pdp.value
  endif

  assign show_section = true
  if is_pdp and pdp_marquee == blank
    assign show_section = false
  endif

  assign meta_bg = nil
  assign meta_color = nil
  if is_pdp and pdp_marquee != blank
    assign meta_bg = pdp_marquee.kolor_tla
    assign meta_color = pdp_marquee.kolor_czcionki
  endif
%}

{% if show_section %}

<script
  src="{{ 'marquee.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% assign gap_between_elements = section.settings.gap_between_elements %}

<div
  class="section-background color-{{ section.settings.color_scheme }}"
  {% if meta_bg != blank %}style="background-color: {{ meta_bg }};"{% endif %}
></div>
<marquee-component
  class="section spacing-style gap-style color-{{ section.settings.color_scheme }}"
  style="
    {%- render 'spacing-style', settings: section.settings %};
    {% render 'gap-style', value: gap_between_elements, name: 'marquee-gap' %}
    --marquee-direction: {{ section.settings.movement_direction }};
    {% if meta_bg != blank %}--marquee-meta-bg: {{ meta_bg }};{% endif %}
    {% if meta_color != blank %}--marquee-meta-color: {{ meta_color }};{% endif %}
  "
  data-speed-factor="{{ section.settings.speed_factor | default: 25 }}"
  data-movement-direction="{{ section.settings.movement_direction }}"
>
  <div
    class="marquee__wrapper"
    ref="wrapper"
  >
    <div
      class="marquee__content"
      ref="content"
    >
      <div
        class="marquee__repeated-items"
        ref="marqueeItems[]"
      >
        {% content_for 'blocks' %}
      </div>
    </div>
  </div>
</marquee-component>

{% endif %}

{% style %}
  @font-face {
    font-family: "SailPL", var(--font-heading--family) !important;
    font-style: normal;
    font-weight: 400;
    font-display: swap;
  }
{% endstyle %}

{% stylesheet %}
  marquee-component {
    display: block;
    width: 100%;
    overflow: hidden;
  }

  .marquee__wrapper {
    display: flex;
    gap: var(--marquee-gap);
    width: fit-content;
    white-space: nowrap;
  }

  .marquee__content {
    min-width: max-content;
    display: flex;
    gap: var(--marquee-gap);
  }

  .marquee__content :is(p, h1, h2, h3, h4, h5, h6) {
    white-space: nowrap;
  }

  .marquee__content .marquee__repeated-items * {
    max-width: none;
  }

  .marquee__repeated-items {
    min-width: max-content;
    display: flex;
    gap: var(--marquee-gap);
    align-items: center;
    justify-content: center;
  }

  .marquee__repeated-items > * {
    align-content: center;
  }

  /* SailPL font and size for all text blocks in marquee */
  /* .marquee__repeated-items .text-block,
  .marquee__repeated-items .text-block * {
    font-family: 'SailPL', var(--font-heading--family) !important;
    font-size: 96px !important;
    line-height: 80px !important;
  } */

  /* @media screen and (max-width: 749px) {
    .marquee__repeated-items .text-block,
    .marquee__repeated-items .text-block * {
      font-size: 48px !important;
      line-height: 32px !important;
    }
  } */

  /* PDP metaobject — background color override */
  marquee-component[style*='--marquee-meta-bg'] {
    background-color: var(--marquee-meta-bg) !important;
  }

  /* PDP metaobject — font color override */
  marquee-component[style*='--marquee-meta-color'] .text-block,
  marquee-component[style*='--marquee-meta-color'] .text-block * {
    color: var(--marquee-meta-color) !important;
  }

  @media (prefers-reduced-motion: no-preference) {
    marquee-component:not([data-disabled]) .marquee__wrapper {
      animation: marquee-motion var(--marquee-speed) linear infinite var(--marquee-direction);
    }
  }

  @keyframes marquee-motion {
    to {
      transform: translate3d(calc(-50% - (var(--marquee-gap) / 2)), 0, 0);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.marquee",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "text"
    },
    {
      "type": "icon"
    },
    {
      "type": "logo"
    },
    {
      "type": "_divider"
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "movement_direction",
      "label": "t:settings.motion_direction",
      "options": [
        {
          "value": "reverse",
          "label": "t:options.forward"
        },
        {
          "value": "normal",
          "label": "t:options.reverse"
        }
      ],
      "default": "normal"
    },
    {
      "type": "range",
      "id": "speed_factor",
      "label": "Speed",
      "info": "Higher value = slower scroll (longer loop). Duration is sqrt(tile copies) × this factor, in seconds.",
      "min": 10,
      "max": 50,
      "step": 1,
      "default": 25
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "gap_between_elements",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "t:names.marquee_section",
      "category": "t:categories.text",
      "blocks": {
        "text": {
          "type": "text",
          "settings": {
            "text": "t:html_defaults.make_things_better",
            "type_preset": "custom",
            "font": "var(--font-body--family)",
            "font_size": "var(--font-size--h2)",
            "line_height": "tight",
            "letter_spacing": "tight",
            "case": "none",
            "wrap": "nowrap",
            "width": "fit-content"
          }
        }
      },
      "block_order": ["text"]
    }
  ]
}
{% endschema %}
