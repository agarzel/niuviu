{% comment %}
  This block is a configuration-only slot for replacing product cards
  at specific positions in the product-list section with a custom image.
{% endcomment %}

{% schema %}
{
  "name": "Product list image slot",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "position",
      "label": "Replace item at position",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 2
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open link in new tab",
      "default": false,
      "visible_if": "{{ block.settings.link != blank }}"
    }
  ],
  "presets": [
    {
      "name": "Product list image slot"
    }
  ]
}
{% endschema %}
