{%- doc -%}
  Sets inline CSS variables for typography styles, including color, font size, weight, family, line height, and letter spacing.
  Intended for use on the style attribute of an element.

  @param {object} typography_settings - Block or section settings (never name this param `settings` — it shadows the global theme `settings` object in snippets and breaks custom typography).
  @param {string} [type] - The type of text element to inherit styles from, options: display, heading, body
  @param {string} [preset] - The type preset; defaults to typography_settings.type_preset

  @example
  <div style="{% render 'typography-style', typography_settings: section.settings %}">
    ...
  </div>
{%- enddoc -%}

{% assign preset = preset | default: typography_settings.type_preset %}
{% if preset == blank and typography_settings.type_preset != blank %}
  {% assign preset = typography_settings.type_preset %}
{% endif %}

{%- capture variables -%}
  {%- if preset != 'rte' -%}
    {% liquid
      assign resolved_color = typography_settings.color
      if preset == 'custom'
        assign resolved_color = typography_settings.text_color | default: typography_settings.color
        if typography_settings.color == 'custom'
          assign resolved_color = typography_settings.color_custom | default: resolved_color
        endif
      elsif typography_settings.color == 'custom'
        assign resolved_color = typography_settings.color_custom | default: 'var(--color-foreground)'
      endif
    %}
    {%- if resolved_color != blank -%}
      --color: {{ resolved_color }};
    {%- endif -%}
  {%- endif -%}
  {%- if preset == 'custom' -%}
    {% liquid
      unless type
        comment
          When choosing to customize the font, picking a specific font size
          determines the type of text block.
        endcomment
        if typography_settings.font_size != ''
          assign font_size_value = typography_settings.font_size | split: 'rem' | first | times: 1.0

          if font_size_value > 4.5
            assign type = 'display'
          elsif font_size_value > 3.5
            assign type = 'heading'
          else
            assign type = 'body'
          endif
        endif
      endunless
    %}
    {%- if typography_settings.font_size != blank -%}
      {%- liquid
        assign font_size_rem = typography_settings.font_size | split: 'rem' | first | times: 1.0
        assign fluid_size_cutoff_rem = 3.0

        if font_size_rem >= fluid_size_cutoff_rem
          assign target_viewport = 1400
          assign vw_value = font_size_rem | times: 16 | divided_by: target_viewport | times: 100

          assign scale_factor = font_size_rem | divided_by: fluid_size_cutoff_rem
          assign base_min_rem = 3.0
          assign scaling_bonus_rem = scale_factor | minus: 1 | times: 0.25
          assign dynamic_min_rem = base_min_rem | plus: scaling_bonus_rem
        endif
      -%}
      {%- if font_size_rem >= fluid_size_cutoff_rem -%}
        --font-size: clamp({{ dynamic_min_rem }}rem, {{ vw_value }}vw, {{ typography_settings.font_size }});
      {%- else -%}
        --font-size: {{ typography_settings.font_size }};
      {%- endif -%}
    {%- endif -%}
    {%- if typography_settings.weight != blank -%}
      --font-weight: {{ typography_settings.weight }};
    {% else %}
      {% if typography_settings.font == 'sailpl' %}
        --font-weight: var(--font-heading--weight);
      {% else %}
        --font-weight: {{ typography_settings.font | replace: 'family', 'weight' }};
      {% endif %}
    {%- endif -%}
    {% if typography_settings.font == 'sailpl' %}
      --font-family: 'SailPL', var(--font-heading--family);
    {% elsif typography_settings.font != blank %}
      --font-family: {{ typography_settings.font }};
    {% else %}
      --font-family: var(--font-body--family);
    {% endif %}
    --text-transform: {{ typography_settings.case }};
    --text-wrap: {{ typography_settings.wrap | default: 'pretty' }};
    {% if typography_settings.type_preset == 'custom' and typography_settings.font_size == blank %}
      --line-height--display: var(--line-height--display-{{ typography_settings.line_height }});
      --line-height--heading: var(--line-height--heading-{{ typography_settings.line_height }});
      --line-height--body: var(--line-height--body-{{ typography_settings.line_height }});
    {% else %}
      --line-height: var(--line-height--{{ type }}-{{ typography_settings.line_height }});
    {% endif %}
    --letter-spacing: var(--letter-spacing--{{ type }}-{{ typography_settings.letter_spacing }});
  {%- endif -%}
{%- endcapture -%}
{{- variables | strip | strip_newlines -}}
